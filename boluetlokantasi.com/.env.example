# ================================================
# Bolu Et Lokantası — Ortam Değişkenleri
# Bu dosyayı .env.local olarak kopyala ve doldur
# ================================================

# Site URL (production'da gerçek domain)
NEXT_PUBLIC_SITE_URL=https://boluetlokantasi.com

# Turso (SQLite) Veritabanı
# https://turso.tech → yeni db oluştur → bağlantı bilgilerini al
TURSO_DATABASE_URL=libsql://veritabani-adi.turso.io
TURSO_AUTH_TOKEN=

# Session Secret — en az 32 karakter rastgele string
# Oluşturmak için: openssl rand -base64 32
SESSION_SECRET=

# Blog API Key — harici sistemler için (opsiyonel)
# Oluşturmak için: openssl rand -base64 32
BLOG_API_KEY=

# İletişim formu e-posta adresi
CONTACT_EMAIL=info@boluetlokantasi.com
