# =============================================
# Düzce Kahvaltı Yerleri — Ortam Değişkenleri
# =============================================
# Bu dosyayı kopyalayıp .env.local olarak kaydedin.
# Vercel'de Settings > Environment Variables bölümüne ekleyin.

# ----- ZORUNLU -----

# JWT ve CSRF için gizli anahtar (en az 32 karakter, rastgele üretin)
# Üretmek için: openssl rand -base64 32
JWT_SECRET=buraya-en-az-32-karakterlik-guclu-bir-anahtar-yazin

# ----- OPSİYONEL (varsayılan değerler çalışır) -----

# Site URL'i
NEXT_PUBLIC_URL=https://duzcekahvaltiyerleri.com

# İşletme bilgileri
NEXT_PUBLIC_BUSINESS_URL=https://ibrahiminyeri.com
NEXT_PUBLIC_BUSINESS_NAME=İbrahim'in Yeri Et Mangal
NEXT_PUBLIC_PHONE=08508888114
NEXT_PUBLIC_PHONE_DISPLAY=0850 888 81 14
NEXT_PUBLIC_ADDRESS=D100 Karayolu, Kaynaşlı, 81900 Düzce

# Sosyal medya
NEXT_PUBLIC_FACEBOOK=https://www.facebook.com/ibrahiminyeriboludagi
NEXT_PUBLIC_INSTAGRAM=https://www.instagram.com/ibrahiminyeriboludagi
NEXT_PUBLIC_YOUTUBE=https://www.youtube.com/@ibrahiminyeri
