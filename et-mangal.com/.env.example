# === Zorunlu ===

# Blog API anahtarı (POST istekleri için, minimum 32 karakter)
BLOG_API_KEY=buraya-guclu-bir-anahtar-yazin-min-32-karakter

# Session Secret (admin oturumları için, minimum 32 karakter)
SESSION_SECRET=rastgele-session-secret-min-32-karakter

# === Veritabanı (Turso) ===
# Turso dashboard'dan alınır: https://turso.tech
TURSO_DATABASE_URL=libsql://your-database-turso.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# === İletişim ===
CONTACT_EMAIL=info@et-mangal.com

# === Opsiyonel ===

# Site URL (varsayılan: https://et-mangal.com)
NEXT_PUBLIC_SITE_URL=https://et-mangal.com

# Google Search Console doğrulama kodu
# NEXT_PUBLIC_GOOGLE_VERIFICATION=your-google-verification-code
