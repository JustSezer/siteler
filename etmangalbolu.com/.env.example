# === DEVELOPMENT (Local SQLite) ===
DATABASE_URL="file:./dev.db"

# === PRODUCTION (Turso Cloud SQLite) ===
# Turso hesabı oluşturun: https://turso.tech
# 1. turso auth login
# 2. turso db create etmangalbolu --location fra
# 3. turso db show etmangalbolu --url  (DATABASE_URL olarak kullanın)
# 4. turso db tokens create etmangalbolu (AUTH_TOKEN olarak)
#
# Vercel ortam değişkenlerini ayarlayın:
# DATABASE_URL="libsql://your-db-turso.turso.io?authToken=your-token"

# === SITE CONFIG ===
SITE_URL="https://etmangalbolu.com"

# === API SECURITY ===
# Güçlü bir rastgele anahtar oluşturun:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET_KEY="min-32-karakter-guclu-anahtar"

# === ADMIN GİRİŞ ===
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="guclu-sifre-degistirin"

# === GOOGLE ANALYTICS ===
# Google Analytics hesabından alın
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
